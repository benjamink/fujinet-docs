#: src/users/n_device/basic_usage.md:106
msgid "TCP Socket Communication"
msgstr ""

#: src/users/n_device/basic_usage.md:108
msgid ""
"The N: device allows BASIC programs to communicate directly over TCP "
"sockets. This enables everything from simple chat clients to BBS terminal "
"programs."
msgstr ""

#: src/users/n_device/basic_usage.md:110
msgid "Simple TCP Client"
msgstr ""

#: src/users/n_device/basic_usage.md:112
msgid ""
"```basic\n"
"10 REM -- Simple TCP echo client\n"
"20 DIM A$(256),B$(256)\n"
"30 OPEN #1,12,0,\"N:TCP://192.168.1.100:6502/\"\n"
"40 PRINT \"Connected! Type text to send.\"\n"
"50 PRINT \"Press RETURN to send, ESC to quit.\"\n"
"60 REM -- Main loop\n"
"70 TRAP 200\n"
"80 INPUT B$\n"
"90 IF B$=\"\" THEN 80\n"
"100 PRINT #1,B$\n"
"110 REM -- Check for response\n"
"120 STATUS #1,A\n"
"130 IF A=0 THEN 80\n"
"140 INPUT #1,A$\n"
"150 PRINT \"Received: \";A$\n"
"160 GOTO 80\n"
"200 CLOSE #1\n"
"210 PRINT \"Disconnected.\"\n"
"```"
msgstr ""

#: src/users/n_device/basic_usage.md:135
msgid ""
"```mermaid\n"
"flowchart TD\n"
"    A[\"OPEN #1,12,0,&quot;N:TCP://host:port/&quot;\"] --> B[Connection "
"Established]\n"
"    B --> C{User Input}\n"
"    C -->|Text entered| D[\"PRINT #1,B$\"]\n"
"    D --> E[\"STATUS #1,A\"]\n"
"    E --> F{Data waiting?}\n"
"    F -->|Yes| G[\"INPUT #1,A$\"]\n"
"    G --> H[Display response]\n"
"    H --> C\n"
"    F -->|No| C\n"
"    C -->|ESC pressed| I[\"CLOSE #1\"]\n"
"```"
msgstr ""

#: src/users/n_device/basic_usage.md:149
msgid "UDP Communication"
msgstr ""

#: src/users/n_device/basic_usage.md:151
msgid ""
"UDP is useful for sending small, quick messages -- for example, in "
"multiplayer game scenarios."
msgstr ""

#: src/users/n_device/basic_usage.md:153
msgid "Sending UDP Packets"
msgstr ""

#: src/users/n_device/basic_usage.md:155
msgid ""
"```basic\n"
"10 REM -- Send UDP data to another FujiNet\n"
"20 OPEN #1,8,0,\"N:UDP://192.168.1.50:5000/\"\n"
"30 PRINT #1,\"HELLO FROM PLAYER 1\"\n"
"40 CLOSE #1\n"
"```"
msgstr ""

#: src/users/n_device/basic_usage.md:162
msgid "Receiving UDP Packets"
msgstr ""

#: src/users/n_device/basic_usage.md:164
msgid ""
"```basic\n"
"10 REM -- Listen for UDP packets\n"
"20 OPEN #1,4,0,\"N:UDP://:5000/\"\n"
"30 TRAP 100\n"
"40 STATUS #1,A\n"
"50 IF A=0 THEN 40\n"
"60 INPUT #1,A$\n"
"70 PRINT \"Received: \";A$\n"
"80 GOTO 40\n"
"100 CLOSE #1\n"
"```"
msgstr ""

