msgstr ""

#: src/users/bbs/connecting.md:28
msgid "Step-by-Step Guide"
msgstr ""

#: src/users/bbs/connecting.md:30
msgid "1. Load the Modem Programs Disk"
msgstr ""

#: src/users/bbs/connecting.md:32
msgid "Power on FujiNet and your Atari. Wait for CONFIG to boot."
msgstr ""

#: src/users/bbs/connecting.md:33
msgid "Select the host slot for `atari-apps.irata.online`."
msgstr ""

#: src/users/bbs/connecting.md:34
msgid "Navigate into the `Atari_8-bit` folder, then the `Comms` folder."
msgstr ""

#: src/users/bbs/connecting.md:35
msgid "Select `modem-programs.atr`."
msgstr ""

#: src/users/bbs/connecting.md:36
msgid "Ensure it is mounted as **R** (read-only) on **D1:**."
msgstr ""

#: src/users/bbs/connecting.md:37
msgid "Press `OPTION` to boot."
msgstr ""

#: src/users/bbs/connecting.md:39
