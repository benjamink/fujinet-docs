#: src/developers/programming/commodore/overview.md:124
msgid "WiFi Operations"
msgstr ""

#: src/developers/programming/commodore/overview.md:126
msgid "Set SSID (Connect to a Network)"
msgstr ""

#: src/developers/programming/commodore/overview.md:128
msgid "**Payload:** `SETSSID:<SSID>,<PASSWORD>`"
msgstr ""

#: src/developers/programming/commodore/overview.md:130
msgid ""
"**Important:** The SSID is case sensitive. Be aware of PETSCII-to-ASCII "
"character conversion when specifying network names."
msgstr ""

#: src/developers/programming/commodore/overview.md:132
msgid ""
"```basic\n"
"OPEN 1,15,15,\"SETSSID:MyNetwork,mypassword\":CLOSE1\n"
"```"
msgstr ""

#: src/developers/programming/commodore/overview.md:136
msgid "RAW Variant"
msgstr ""

#: src/developers/programming/commodore/overview.md:138
msgid "**Payload:** `SETSSID:RAW:` followed by exactly 97 bytes of binary data:"
msgstr ""

#: src/developers/programming/commodore/overview.md:142
#: src/developers/programming/commodore/overview.md:143
msgid "// NULL-padded\n"
msgstr ""

#: src/developers/programming/commodore/overview.md:147
msgid ""
"The structure is appended immediately after `SETSSID:RAW:` and must be "
"exactly 97 characters. Both fields are NULL-padded."
msgstr ""

#: src/developers/programming/commodore/overview.md:149
msgid "Get Current SSID"
msgstr ""

#: src/developers/programming/commodore/overview.md:151
msgid "**Payload:** `GETSSID`"
msgstr ""

#: src/developers/programming/commodore/overview.md:153
msgid ""
"**Response:** A single line of text containing the currently configured SSID."
msgstr ""

#: src/developers/programming/commodore/overview.md:155
msgid ""
"```basic\n"
"10 OPEN 1,15,15,\"GETSSID\"\n"
"20 INPUT#1,S$\n"
"21 CLOSE1\n"
"30 ? \"SSID: \";S$\n"
"40 END\n"
"```"
msgstr ""

#: src/developers/programming/commodore/overview.md:163
msgid "Scan for Networks"
msgstr ""

#: src/developers/programming/commodore/overview.md:165
msgid "**Payload:** `SCAN`"
msgstr ""

#: src/developers/programming/commodore/overview.md:167
msgid ""
"**Response:** A single number indicating the count of discovered networks."
msgstr ""

#: src/developers/programming/commodore/overview.md:169
msgid ""
"```basic\n"
"10 OPEN 1,15,15,\"SCAN\"\n"
"20 INPUT#1,N\n"
"30 CLOSE1\n"
"40 PRINT \"# OF NETWORKS FOUND: \";N\n"
"50 END\n"
"```"
msgstr ""

#: src/developers/programming/commodore/overview.md:177
msgid "Get Scan Result"
msgstr ""

#: src/developers/programming/commodore/overview.md:179
msgid "**Payload:** `SCANRESULT:<num>` (text) or `SCANRESULT:<num>:RAW` (binary)"
msgstr ""

#: src/developers/programming/commodore/overview.md:181
msgid "**Text response:** `\"SSID\",RSSI`"
msgstr ""

#: src/developers/programming/commodore/overview.md:183
msgid ""
"```basic\n"
"60 OPEN 1,15,15,\"SCANRESULT:1\"\n"
"70 INPUT#1,S$,R:REM GET SSID AND RSSI\n"
"71 CLOSE 1\n"
"80 ? \"SSID: \";S$;\" RSSI: \";R\n"
"```"
msgstr ""

#: src/developers/programming/commodore/overview.md:190
msgid "**RAW binary structure:**"
msgstr ""

#: src/developers/programming/commodore/overview.md:194
msgid "// NULL-terminated and padded\n"
msgstr ""

#: src/developers/programming/commodore/overview.md:199
msgid "Get WiFi Status"
msgstr ""

#: src/developers/programming/commodore/overview.md:201
msgid "**Payload:** `WIFISTATUS`"
msgstr ""

#: src/developers/programming/commodore/overview.md:203
msgid "**Response:** `3` = connected, `6` = disconnected."
msgstr ""

#: src/developers/programming/commodore/overview.md:205
msgid ""
"```basic\n"
"10 OPEN 1,15,15,\"WIFISTATUS\"\n"
"20 INPUT #1,S\n"
"30 CLOSE 1\n"
"40 PRINT \"WIFI STATUS IS \";\n"
"50 IF S=3 THEN PRINT \"CONNECTED\"\n"
"60 IF S=6 THEN PRINT \"DISCONNECTED\"\n"
"70 END\n"
"```"
msgstr ""

#: src/developers/programming/commodore/overview.md:215
msgid "Host and Device Slot Operations"
msgstr ""

#: src/developers/programming/commodore/overview.md:217
msgid "Mount Host Slot"
msgstr ""

#: src/developers/programming/commodore/overview.md:219
msgid "**Payload:** `MOUNTHOST:<0-7>`"
msgstr ""

#: src/developers/programming/commodore/overview.md:221
msgid ""
"Mount the host configured at the specified slot (0-7). This must be done "
"before a device slot referencing that host can be used."
msgstr ""

#: src/developers/programming/commodore/overview.md:223
msgid ""
"```basic\n"
"OPEN 1,15,15,\"MOUNTHOST:1\":CLOSE1:REM MOUNT SECOND HOST SLOT\n"
"```"
msgstr ""

#: src/developers/programming/commodore/overview.md:227
msgid "Mount Device Slot"
msgstr ""

#: src/developers/programming/commodore/overview.md:229
msgid "**Payload:** `MOUNTDRIVE:<0-3>:<MODE>`"
msgstr ""

#: src/developers/programming/commodore/overview.md:231
msgid ""
"Mount the device at the specified slot (0-3) with the given mode (1 = read, "
"2 = write). Device slots 0-3 correspond to IEC devices 8-11."
msgstr ""

#: src/developers/programming/commodore/overview.md:233
msgid ""
"```basic\n"
"OPEN 1,15,15,\"MOUNTDRIVE:0\":CLOSE1:REM MOUNT FIRST DEVICE SLOT\n"
"```"
msgstr ""

#: src/developers/programming/commodore/overview.md:237
msgid "Open Directory"
msgstr ""

#: src/developers/programming/commodore/overview.md:239
msgid "**Payload:** `OPENDIR:<0-7>:</PATH>[~FILTER]`"
msgstr ""

#: src/developers/programming/commodore/overview.md:241
msgid ""
"Opens a directory listing for a mounted host slot. The tilde (`~`) character "
"substitutes for the NULL separator between path and filter pattern. Use "
"`READDIR` to retrieve entries."
msgstr ""

#: src/developers/programming/commodore/overview.md:243
msgid ""
"```basic\n"
"OPEN1,15,15,\"OPENDIR:0:/~*.D64\":CLOSE1:REM LIST .D64 FILES\n"
"```"
msgstr ""

