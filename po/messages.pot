#: src/users/quickstart/commodore.md:114 src/users/n_device/protocols.md:232
msgid "TNFS"
msgstr ""

#: src/users/quickstart/commodore.md:114
msgid "Standard FujiNet protocol for accessing TNFS servers"
msgstr ""

#: src/users/quickstart/commodore.md:115
msgid "**Meatloaf (ML)**"
msgstr ""

#: src/users/quickstart/commodore.md:115 src/users/n_device/basic_usage.md:218
#: src/developers/programming/apple/overview.md:181
msgid "8"
